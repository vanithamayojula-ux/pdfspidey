{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "User's profile picture URL" },
        "createdAt": { "type": "number", "description": "Timestamp when the user account was created" }
      },
      "required": ["uid", "email"]
    },
    "PDF": {
      "title": "PDF",
      "description": "Metadata for a PDF document stored in Firestore (optional sync)",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the PDF" },
        "userId": { "type": "string", "description": "ID of the user who owns the PDF" },
        "name": { "type": "string", "description": "Name of the PDF file" },
        "category": { "type": "string", "description": "Category of the PDF" },
        "folderId": { "type": "number", "description": "ID of the folder containing the PDF" },
        "size": { "type": "number", "description": "Size of the PDF in bytes" },
        "createdAt": { "type": "number", "description": "Timestamp when the PDF was added" }
      },
      "required": ["userId", "name", "category", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/users/{userId}/pdfs/{pdfId}": {
      "schema": "PDF",
      "description": "User-specific PDF metadata"
    }
  }
}
